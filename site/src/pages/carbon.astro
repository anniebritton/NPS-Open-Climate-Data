---
import Base from "../layouts/Base.astro";
import carbon from "../../public/data/carbon.json";
const base = import.meta.env.BASE_URL;

const info = (carbon as any).build_info ?? null;
const n_commits = info?.commit_count ?? 0;
const a = (carbon as any).assumptions ?? {};

const claudeInK  = Math.round((a.claude_in_per_commit  ?? 50_000) * n_commits / 1000
                             + (a.claude_in_baseline   ?? 300_000) / 1000);
const claudeOutK = Math.round((a.claude_out_per_commit ?? 10_000) * n_commits / 1000
                             + (a.claude_out_baseline  ?? 60_000)  / 1000);
const ciRuns = n_commits * (a.ci_runs_per_commit ?? 2);

const buildTotal = carbon.total_build_g;
const generatedAt = info?.generated_at ? new Date(info.generated_at) : null;
const generatedPretty = generatedAt ? generatedAt.toUTCString() : null;

// Everyday-comparison divisors, order-of-magnitude from published sources.
const compares = [
  { n: buildTotal / 120,           unit: "km in an average gas car", decimals: 1, ref: 8 },
  { n: buildTotal / 36,            unit: "hours of video streaming", decimals: 1, ref: 7 },
  { n: Math.round(buildTotal / 0.2),unit: "Google searches",         decimals: 0, ref: 1 },
  { n: Math.round(buildTotal / 8), unit: "smartphone charges",       decimals: 0, ref: 4 },
];

const lineItemsRaw = [
  {
    label: "Earth Engine processing",
    g: carbon.ee_processing_g,
    color: "#2a6041",
    cadence: "one-time",
    notes: "Serverless Earth Engine batch tasks, run once per full pipeline.",
    rows: [
      { k: "Scope",     v: "63 parks, processed once" },
      { k: "CPU time",  v: `${a.ee_cpu_min_per_park} min/park` },
      { k: "Intensity", v: `${a.ee_Wh_per_cpu_hr} Wh/CPU-hr [3]` },
    ],
  },
  {
    label: "Data egress from EE → Drive",
    g: carbon.ee_egress_g,
    color: "#4a7fa5",
    cadence: "one-time",
    notes: "Daily DAYMET + ERA5 tables transferred out of EE storage.",
    rows: [
      { k: "Volume",    v: `${a.raw_MB_per_park} MB/park × 63 ≈ ${((a.raw_MB_per_park * 63) / 1024).toFixed(1)} GB` },
      { k: "Intensity", v: `${a.egress_Wh_per_GB} Wh/GB [4]` },
    ],
  },
  {
    label: "Local statistical analysis",
    g: carbon.local_analysis_g,
    color: "#7a5c8b",
    cadence: "one-time",
    notes: "Annual aggregates, Mann–Kendall tests, Theil–Sen slopes. Runs on a laptop.",
    rows: [
      { k: "CPU time", v: `${a.local_cpu_sec_per_park} s/park` },
      { k: "Draw",     v: `${a.local_power_W} W` },
    ],
  },
  {
    label: "Claude API — all dev sessions",
    g: carbon.claude_api_g,
    color: "#b5613b",
    cadence: "accrues per commit",
    notes: `Cumulative across all ${n_commits} commits. Every new conversation adds to the running total.`,
    rows: [
      { k: "Tokens to date", v: `~${claudeInK.toLocaleString()}k input · ~${claudeOutK.toLocaleString()}k output` },
      { k: "Baseline",       v: `${Math.round((a.claude_in_baseline  ?? 300000) / 1000)}k in + ${Math.round((a.claude_out_baseline ?? 60000)  / 1000)}k out` },
      { k: "Per commit",     v: `+${Math.round((a.claude_in_per_commit  ?? 50000) / 1000)}k in · +${Math.round((a.claude_out_per_commit ?? 10000) / 1000)}k out` },
      { k: "Intensity",      v: `${a.claude_input_Wh_per_kt} Wh/1k input · ${a.claude_output_Wh_per_kt} Wh/1k output [5]` },
    ],
  },
  {
    label: "GitHub Actions CI — all builds",
    g: (carbon as any).ci_actions_g,
    color: "#c79a3b",
    cadence: "accrues per commit",
    notes: "Every push to main runs the build and test suite on a GitHub-hosted runner.",
    rows: [
      { k: "Runs to date", v: `${ciRuns.toLocaleString()} workflow runs` },
      { k: "Per run",      v: `${a.ci_minutes_per_run} min × ${a.ci_vcpus} vCPU × ${a.ci_W_per_vcpu} W/vCPU [6]` },
    ],
  },
];
// Sort largest contributor first so the bar reads left → right
// (most → least) and the line-item list follows the same order.
const lineItems = [...lineItemsRaw].sort((a, b) => (b.g ?? 0) - (a.g ?? 0));
const maxG = Math.max(...lineItems.map((x) => x.g));

const sources = [
  { title: "Google 2024 Environmental Report",
    authors: "Google", year: 2024,
    url: "https://sustainability.google/reports/google-2024-environmental-report/",
    domain: "sustainability.google" },
  { title: "Electricity 2024 — Analysis and forecast to 2026",
    authors: "IEA", year: 2024,
    url: "https://www.iea.org/reports/electricity-2024",
    domain: "iea.org" },
  { title: "Recalibrating global data center energy-use estimates (Science, 367)",
    authors: "Masanet, Shehabi, Lei, Smith, Koomey", year: 2020,
    url: "https://www.science.org/doi/10.1126/science.aba3758",
    domain: "science.org" },
  { title: "Electricity intensity of internet data transmission (J. Industrial Ecology, 22)",
    authors: "Aslan, Mayers, Koomey, France", year: 2018,
    url: "https://onlinelibrary.wiley.com/doi/10.1111/jiec.12630",
    domain: "wiley.com" },
  { title: "Estimating the carbon footprint of BLOOM (JMLR 24) + Anthropic disclosures",
    authors: "Luccioni, Viguier, Ligozat", year: 2023,
    url: "https://jmlr.org/papers/v24/23-0069.html",
    domain: "jmlr.org" },
  { title: "About GitHub-hosted runners — hardware specifications",
    authors: "GitHub", year: 2024,
    url: "https://docs.github.com/en/actions/using-github-hosted-runners/using-github-hosted-runners/about-github-hosted-runners",
    domain: "docs.github.com" },
  { title: "The real climate and transformative impact of ICT (Patterns, 2)",
    authors: "Freitag, Berners-Lee, Widdicks, Knowles, Blair, Friday", year: 2021,
    url: "https://www.cell.com/patterns/fulltext/S2666-3899(21)00188-4",
    domain: "cell.com" },
  { title: "Greenhouse gas emissions from a typical passenger vehicle",
    authors: "U.S. EPA", year: 2023,
    url: "https://www.epa.gov/greenvehicles/greenhouse-gas-emissions-typical-passenger-vehicle",
    domain: "epa.gov" },
];
---
<Base title="Carbon footprint — Open Climate Data">
  <section class="container section carbon-page">
    <a href={base} class="carbon-back">← Home</a>
    <span class="kicker" style="margin-top:0.8rem;display:block">Transparency</span>
    <h1>What did this site cost the climate?</h1>
    <p class="carbon-lede">
      These numbers are order-of-magnitude estimates of
      the CO₂-equivalent emissions from producing the data, building
      the site, hosting it, and viewing it.
    </p>

    <!-- Hero ledger stat -->
    <div class="carbon-hero">
      <div class="carbon-hero-big">
        <span class="carbon-hero-num" data-count-to={buildTotal.toFixed(0)}>0</span>
        <span class="carbon-hero-unit">g CO₂e</span>
      </div>
      <div class="carbon-hero-meta">
        <span class="carbon-hero-meta-label">Cumulative project total</span>
        {info && (
          <span class="carbon-hero-meta-sub">
            {info.commit_count} commits · this build{" "}
            <a href={`https://github.com/anniebritton/NPS-Open-Climate-Data/commit/${info.commit}`}>
              <code>{info.commit}</code>
            </a>
            {generatedPretty && <> · generated {generatedPretty}</>}
          </span>
        )}
      </div>
    </div>

    <!-- That's roughly… comparison pills -->
    <div class="carbon-compare">
      <span class="carbon-compare-label">That's roughly equivalent to</span>
      <div class="carbon-compare-grid">
        {compares.map((c) => (
          <div class="carbon-compare-pill">
            <span class="carbon-compare-num">{c.decimals ? c.n.toFixed(c.decimals) : c.n.toLocaleString()}</span>
            <span class="carbon-compare-unit">{c.unit}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Stacked proportional bar -->
    <div class="carbon-stack-wrap">
      <div class="carbon-stack-head">
        <span class="carbon-stack-kicker">Breakdown</span>
        <span class="carbon-stack-hint">Hover for amounts</span>
      </div>
      <div class="carbon-stack" role="img" aria-label="Proportional breakdown of emissions">
        {lineItems.map((r) => (
          <div
            class="carbon-stack-seg"
            style={`flex-grow:${r.g}; background:${r.color};`}
            data-label={r.label}
            data-g={r.g.toFixed(1)}
            data-pct={((r.g / buildTotal) * 100).toFixed(1)}
          ></div>
        ))}
        <div id="carbon-stack-tooltip" class="carbon-stack-tooltip" role="tooltip"></div>
      </div>
      <div class="carbon-stack-legend">
        {lineItems.map((r) => (
          <div class="carbon-stack-legend-item">
            <span class="carbon-stack-swatch" style={`background:${r.color}`}></span>
            <span class="carbon-stack-name">{r.label.replace(" — all dev sessions", "").replace(" — all builds", "")}</span>
            <span class="carbon-stack-pct">{((r.g / buildTotal) * 100).toFixed(1)}%</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Expandable ledger line items -->
    <div class="carbon-section-head">
      <h2>Line items</h2>
      <span class="carbon-section-hint">Click any row to reveal its assumptions</span>
    </div>
    <div class="carbon-ledger">
      {lineItems.map((item) => (
        <details class="carbon-line">
          <summary class="carbon-line-summary">
            <span class="carbon-line-swatch" style={`background:${item.color}`}></span>
            <span class="carbon-line-label">
              {item.label}
              <span class="carbon-line-cadence">{item.cadence}</span>
            </span>
            <span class="carbon-line-bar-wrap">
              <span class="carbon-line-bar" style={`width:${(item.g / maxG) * 100}%;background:${item.color}`}></span>
            </span>
            <span class="carbon-line-value">
              <span class="num">{item.g.toFixed(1)}</span>
              <span class="unit">g</span>
            </span>
            <span class="carbon-line-caret" aria-hidden="true">↓</span>
          </summary>
          <div class="carbon-line-detail">
            <p class="carbon-line-notes">{item.notes}</p>
            <dl class="carbon-line-rows">
              {item.rows.map((r) => (
                <div>
                  <dt>{r.k}</dt>
                  <dd>{r.v}</dd>
                </div>
              ))}
            </dl>
          </div>
        </details>
      ))}
    </div>

    <!-- Recurring costs -->
    <div class="carbon-section-head">
      <h2>Recurring cost per reader</h2>
      <span class="carbon-section-hint">After the project is built, each visit is nearly free</span>
    </div>
    <div class="carbon-recurring">
      <div class="carbon-recurring-item">
        <div class="carbon-recurring-num">{carbon.per_view_g.toFixed(3)}<span class="carbon-recurring-unit">g CO₂e</span></div>
        <div class="carbon-recurring-label">Per page view</div>
        <div class="carbon-recurring-detail">
          A 60-second read on a phone. ~{a.view_MB} MB transfer at {a.view_device_W} W.
        </div>
      </div>
      <div class="carbon-recurring-item">
        <div class="carbon-recurring-num">{carbon.hosting_per_month_g.toFixed(0)}<span class="carbon-recurring-unit">g CO₂e</span></div>
        <div class="carbon-recurring-label">Hosting per month</div>
        <div class="carbon-recurring-detail">
          GitHub Pages serving ~10,000 monthly views. ~{a.pages_Wh_per_GB} Wh/GB.
        </div>
      </div>
    </div>

    <div class="note carbon-note">
      <strong>Why this matters.</strong> By publishing pre-computed aggregates
      and trends instead of asking every visitor to run their own Earth Engine
      jobs, we amortize the ~{buildTotal.toFixed(0)} g project cost across tens
      of thousands of readers, for <em>&lt; 1 g</em> of CO₂e per visit. Grid
      intensity assumed at {a.grid_intensity_g_per_kWh} g/kWh (between Google
      Cloud's reported ~300 g/kWh <a href="#ref-1" class="cite">[1]</a> and the
      IEA's 2023 global average of ~480 g/kWh <a href="#ref-2" class="cite">[2]</a>).
    </div>

    <!-- Sources -->
    <div class="carbon-section-head">
      <h2>Sources</h2>
    </div>
    <ol class="carbon-sources">
      {sources.map((s, i) => (
        <li id={`ref-${i + 1}`}>
          <span class="carbon-source-num">[{i + 1}]</span>
          <div class="carbon-source-body">
            <div class="carbon-source-title">{s.title}</div>
            <div class="carbon-source-meta">
              {s.authors} · {s.year}
              {s.url && (<> · <a href={s.url} target="_blank" rel="noopener">{s.domain}</a></>)}
            </div>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <script is:inline>
    // Count-up animation on the hero big number.
    (function () {
      const el = document.querySelector(".carbon-hero-num[data-count-to]");
      if (!el) return;
      const target = Number(el.dataset.countTo);
      if (!isFinite(target)) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        el.textContent = String(target);
        return;
      }
      const duration = 900;
      const start = performance.now();
      function frame(now) {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = String(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    })();

    // Cursor-following tooltip on the breakdown bar. Replaces the
    // browser's default title-attribute tooltip, which on macOS/Windows
    // pairs with a help cursor that looks like a stray question mark.
    (function () {
      const stack = document.querySelector(".carbon-stack");
      const tip = document.getElementById("carbon-stack-tooltip");
      if (!stack || !tip) return;
      stack.addEventListener("mousemove", (e) => {
        const seg = e.target.closest(".carbon-stack-seg");
        if (!seg) { tip.classList.remove("active"); return; }
        const rect = stack.getBoundingClientRect();
        const label = seg.dataset.label || "";
        const g = seg.dataset.g || "";
        const pct = seg.dataset.pct || "";
        tip.innerHTML = `<strong>${label}</strong><span>${g} g · ${pct}%</span>`;
        tip.style.left = (e.clientX - rect.left) + "px";
        tip.style.top = (e.clientY - rect.top) + "px";
        tip.classList.add("active");
      });
      stack.addEventListener("mouseleave", () => tip.classList.remove("active"));
    })();
  </script>
</Base>

<style>
  .cite {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    vertical-align: super;
    text-decoration: none;
    color: var(--accent);
    margin-left: 1px;
  }
  .cite:hover { color: var(--canyon-deep); }
</style>
