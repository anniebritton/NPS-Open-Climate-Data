---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;

const pipelineScript = `git clone https://github.com/anniebritton/NPS-Open-Climate-Data
cd NPS-Open-Climate-Data
pip install -e .

# 1. Submit serverless EE export tasks (needs a GCP project with EE enabled).
#    Runs on Google's servers; close the laptop after submit.
python -c "import ee; ee.Authenticate(auth_mode='localhost'); ee.Initialize(project='YOUR_PROJECT')"
python scripts/01_export_all_parks.py --start 1980-01-01

# 2. When the tasks show COMPLETED at code.earthengine.google.com/tasks,
#    pull the CSVs from Drive (needs gcloud ADC with Drive scope).
python scripts/07_download_from_drive.py --drive-folder NPS_Climate_Data

# 3. Aggregate, run trend tests, write site JSON.
python scripts/02_build_site_data.py

# 4. Extract real PAD-US boundaries from a local v4.1 GDB (optional —
#    committed boundaries are already in the repo).
python scripts/06_extract_padus_from_gdb.py
python scripts/05_generate_boundaries.py

# 5. Build and preview the static site locally.
cd site && npm install && npm run dev`;

const programmaticScript = `import ee, nps_climate_data as nps
ee.Initialize()

# One park, one date range:
df = nps.get_data("Glacier National Park", "2020-01-01", "2025-01-01")

# Full-history fetch with multipart handling (dict of sub-unit -> DataFrame):
per_unit = nps.get_park_data("saguaro")`;

const citationProse = `Britton, A., & Pritchard, I. (2026). NPS Open Climate Data v1.0.0: Pre-processed climate trends for all 63 US National Parks [Data set]. Zenodo. https://doi.org/10.5281/zenodo.19823584`;

const citationBibtex = `@dataset{britton2026nps,
  author       = {Britton, Annie and Pritchard, Ian},
  title        = {{NPS Open Climate Data v1.0.0: Pre-processed climate
                  trends for all 63 US National Parks}},
  year         = {2026},
  publisher    = {Zenodo},
  version      = {v1.0.0},
  doi          = {10.5281/zenodo.19823584},
  url          = {https://doi.org/10.5281/zenodo.19823584}
}`;

const citationApa = `Britton, A., & Pritchard, I. (2026). NPS Open Climate Data v1.0.0: Pre-processed climate trends for all 63 US National Parks [Data set]. Zenodo. https://doi.org/10.5281/zenodo.19823584`;

// The full versioned dataset is on Zenodo. Each archive is a self-
// contained zip; users pick whichever subset(s) they need.
const zenodoRecord = "19823584";
const zenodoDoi = "10.5281/zenodo.19823584";
const zenodoBase = `https://zenodo.org/records/${zenodoRecord}/files`;
const zenodoArchives = [
  { title: "Everything (single zip)",
    file: "nps-open-climate-data-v1.0.0-all.zip",
    size: "178 MB",
    desc: "All four archives below in one download. Use this for offline analysis." },
  { title: "Daily CSVs (gzipped)",
    file: "nps-open-climate-data-v1.0.0-daily.zip",
    size: "150 MB",
    desc: "Raw 1980–2025 daily series per park in DAYMET / ERA5 native units (K, m, kg/m², W/m², Pa). Multipart parks ship one .csv.gz per polygon." },
  { title: "Park summaries (JSON)",
    file: "nps-open-climate-data-v1.0.0-summary.zip",
    size: "24 MB",
    desc: "Per-park summary JSONs — annual + seasonal aggregates, Mann–Kendall / Theil–Sen trends, monthly decomposition, climate stripes — plus parks.json index. Temperatures in °C." },
  { title: "Park boundaries (GeoJSON)",
    file: "nps-open-climate-data-v1.0.0-boundaries.zip",
    size: "3 MB",
    desc: "PAD-US 4.1 proclamation polygons dissolved per park, simplified to 50 m, in WGS84. Includes all_parks.geojson FeatureCollection." },
];

// Convenience endpoints: same content as the Zenodo summary / boundary
// archives, but individually addressable for one-off lookups without
// having to download and unzip the whole archive.
const liveEndpoints = [
  { title: "Per-park summary JSON",
    path: `${base}data/parks/<slug>.json`,
    example: `${base}data/parks/yellowstone.json`,
    desc: "Single park, served live. Same shape as the Zenodo summary archive." },
  { title: "Per-park boundary GeoJSON",
    path: `${base}data/boundaries/<slug>.geojson`,
    example: `${base}data/boundaries/yellowstone.geojson`,
    desc: "PAD-US 4.1 polygon for one park, in WGS84." },
  { title: "All-parks boundary FeatureCollection",
    path: `${base}data/boundaries/all_parks.geojson`,
    example: `${base}data/boundaries/all_parks.geojson`,
    desc: "All 63 parks in one FeatureCollection, with each park's headline warming slope exposed as feature properties." },
];

const downloadHelperScript = `# Pure-stdlib helper that pulls + caches the Zenodo archives, then
# returns a pandas DataFrame for any park's daily series:
import nps_climate_data as nps

df  = nps.fetch_daily("yellowstone")     # raw daily CSV → DataFrame
sj  = nps.fetch_summary("yellowstone")   # summary JSON → dict
arc = nps.fetch_archive("boundaries")    # downloads + extracts the zip

# Caches under ~/.cache/nps_climate_data so subsequent calls are local.`;
---
<Base title="Data — Open Climate Data">
  <!-- schema.org Dataset markup so crawlers + AI agents understand
       the dataset without parsing prose. Mirrors the home-page block. -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "NPS Open Climate Data v1.0.0",
    "description": "Pre-processed climate time series, Mann–Kendall + Theil–Sen trend tests, and monthly trend / seasonal-cycle decomposition for every one of the 63 US National Parks. Built on DAYMET v4, ERA5-Land, and USGS PAD-US 4.1 via Google Earth Engine.",
    "url": "https://anniebritton.github.io/NPS-Open-Climate-Data/data/",
    "identifier": ["10.5281/zenodo.19823584", "https://doi.org/10.5281/zenodo.19823584"],
    "version": "v1.0.0",
    "license": "https://opensource.org/licenses/MIT",
    "isAccessibleForFree": true,
    "creator": [
      { "@type": "Person", "name": "Annie Britton" },
      { "@type": "Person", "name": "Ian Pritchard" },
    ],
    "publisher": { "@type": "Organization", "name": "Zenodo" },
    "temporalCoverage": "1980-01-01/2025-12-31",
    "distribution": zenodoArchives.map((r) => ({
      "@type": "DataDownload",
      "encodingFormat": "application/zip",
      "name": r.title + " (" + r.size + ")",
      "contentUrl": `${zenodoBase}/${r.file}`,
    })),
    "citation": citationProse,
  })} />
  <section class="container section research-page">
    <a href={base} class="research-back">← Home</a>
    <span class="kicker" style="margin-top:0.8rem;display:block">Data</span>
    <h1>Data products, code, and reproducibility</h1>

    <!-- Open downloads — first, since it's why most people are here -->
    <section id="downloads" class="research-section">
      <div class="research-section-intro">
        <span class="kicker">Data</span>
        <h2>Open downloads</h2>
        <p>
          Canonical distribution is the versioned <strong>Zenodo
          deposit</strong> (DOI <a href={`https://doi.org/${zenodoDoi}`} target="_blank" rel="noopener"><code>{zenodoDoi}</code></a>).
          Four download options below; pick the subset you need.
          MIT-licensed. Temperatures stored in SI (°C); the website
          converts to °F at render only.
        </p>
      </div>
      <div class="research-section-content">
        <div class="research-resources">
          {zenodoArchives.map((r) => (
            <article class="research-resource">
              <header>
                <span class="research-resource-title">
                  {r.title}
                  <span class="research-resource-size">{r.size}</span>
                </span>
                <a class="research-copy" href={`${zenodoBase}/${r.file}?download=1`} target="_blank" rel="noopener">Download</a>
              </header>
              <code class="research-resource-path">{r.file}</code>
              <p>{r.desc}</p>
            </article>
          ))}
        </div>

        <h3 class="research-subhead">Per-format usage</h3>
        <ul class="research-usage">
          <li>
            <strong>Unzip the archive</strong> — every zip extracts to a
            single <code>nps-open-climate-data-v1.0.0/</code> folder:
            <pre><code>unzip nps-open-climate-data-v1.0.0-summary.zip</code></pre>
          </li>
          <li>
            <strong>Daily CSVs are gzipped</strong> — read directly
            with pandas (auto-detects the <code>.gz</code> extension)
            or decompress first:
            <pre><code>{`# in Python
import pandas as pd
df = pd.read_csv("daily/yellowstone/yellowstone.csv.gz")

# from the shell
gunzip daily/yellowstone/yellowstone.csv.gz`}</code></pre>
          </li>
          <li>
            <strong>Summary JSONs</strong> are plain JSON; load with
            any standard parser. Schema lives on the
            <a href={base + "methodology"}>Methodology</a> page.
            <pre><code>{`import json
summary = json.load(open("summary/yellowstone.json"))
print(summary["headline_trends"]["tmean_c"])`}</code></pre>
          </li>
          <li>
            <strong>GeoJSON boundaries</strong> open natively in
            QGIS, geopandas, Mapbox, Leaflet, etc.
            <pre><code>{`import geopandas as gpd
gdf = gpd.read_file("boundaries/yellowstone.geojson")`}</code></pre>
          </li>
        </ul>

        <h3 class="research-subhead">Programmatic helper (Python)</h3>
        <p>
          The Python package ships a small Zenodo download helper.
          It pulls the archive on first use, caches under
          <code>~/.cache/nps_climate_data/</code>, and returns ready-
          to-use objects:
        </p>
        <figure class="research-code">
          <figcaption>
            <span class="research-code-lang">python</span>
            <button class="research-copy" data-copy-target>Copy</button>
          </figcaption>
          <pre><code>{downloadHelperScript}</code></pre>
        </figure>

        <h3 class="research-subhead">For agents</h3>
        <p>
          Point an AI assistant at
          <a href={`${base}llms.txt`}><code>/llms.txt</code></a>
          for a structured pointer to the dataset, download URLs,
          Python helpers, schema, and limitations. The Python helper
          (<code>nps.fetch_daily(slug)</code>, etc.) is the simplest
          path for an agent to actually fetch a park's series — it
          handles the Zenodo download, gunzip, and parsing in one call.
          The same information is also exposed as
          <a href="https://schema.org/Dataset" target="_blank" rel="noopener">schema.org/Dataset</a>
          JSON-LD on this page and the home page so structured-data
          crawlers pick it up too.
        </p>

        <h3 class="research-subhead">Single-park lookups (live site)</h3>
        <p>
          The site also serves individual files at predictable URLs —
          handy for fetching one park without downloading the whole
          Zenodo archive.
        </p>
        <div class="research-resources">
          {liveEndpoints.map((r) => (
            <article class="research-resource">
              <header>
                <span class="research-resource-title">{r.title}</span>
                {r.example && (
                  <button class="research-copy" data-copy={r.example}>Copy example URL</button>
                )}
              </header>
              <code class="research-resource-path">{r.path}</code>
              <p>{r.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Use responsibly — second, after the actual downloads -->
    <section class="research-section">
      <div class="research-section-intro">
        <span class="kicker">Use responsibly</span>
        <h2>Verify before you cite</h2>
        <p>
          These products are open-licensed under MIT and audited
          internally against literature anchors and arithmetic / range
          / consistency checks (see
          <a href={base + "methodology#qc"}>Methodology &rarr; QC</a>
          and <a href="https://github.com/anniebritton/NPS-Open-Climate-Data/blob/main/docs/DATA_QC.md"
             target="_blank" rel="noopener"><code>docs/DATA_QC.md</code></a>).
          They are <em>derived</em> products — polygon-averaged
          ERA5-Land and DAYMET fields aggregated over PAD-US 4.1
          boundaries, not station observations.
        </p>
      </div>
      <div class="research-section-content">
        <ol class="research-steps">
          <li>
            <strong>Re-derive the value.</strong> Re-run the pipeline
            from raw, or independently compute the variable of interest
            from DAYMET / ERA5-Land directly, and confirm it matches.
          </li>
          <li>
            <strong>Cross-check stations.</strong> Compare against
            NOAA NCEI, NWS, or NPS monitoring records for the specific
            park and variable.
          </li>
          <li>
            <strong>Correct your statistics.</strong> Apply
            autocorrelation handling (Hamed–Rao MK) and multiple-
            comparisons correction (Benjamini–Hochberg FDR or
            Bonferroni). The deployed significance flags do neither.
          </li>
          <li>
            <strong>Read the variable-specific limitations.</strong>
            See <a href={base + "methodology#limitations"}>methodology &rarr; limitations</a>,
            especially <code>pet_mm</code> (ERA5-Land overestimate vs
            FAO Penman–Monteith), high-elevation cold bias, and area-
            naive multipart averaging.
          </li>
        </ol>
        <p class="research-steps-note">
          Cite the methodology page, run your own QC for your use case,
          and treat the published numbers as a starting point.
        </p>
      </div>
    </section>

    <!-- Reproduce -->
    <section class="research-section">
      <div class="research-section-intro">
        <span class="kicker">Reproduce</span>
        <h2>End-to-end pipeline</h2>
        <p>
          The full auth → EE export → Drive pull → analysis → site build
          flow lives in <code>pipeline.ipynb</code>. This is the condensed
          terminal version.
        </p>
      </div>
      <div class="research-section-content">
        <figure class="research-code">
          <figcaption>
            <span class="research-code-lang">bash</span>
            <button class="research-copy" data-copy-target>Copy</button>
          </figcaption>
          <pre><code>{pipelineScript}</code></pre>
        </figure>
      </div>
    </section>

    <!-- Programmatic -->
    <section class="research-section">
      <div class="research-section-intro">
        <span class="kicker">API</span>
        <h2>Programmatic access</h2>
        <p>
          Direct Python access via the <code>nps_climate_data</code> package
          after <code>pip install -e .</code>. EE credentials must already be
          initialised.
        </p>
      </div>
      <div class="research-section-content">
        <figure class="research-code">
          <figcaption>
            <span class="research-code-lang">python</span>
            <button class="research-copy" data-copy-target>Copy</button>
          </figcaption>
          <pre><code>{programmaticScript}</code></pre>
        </figure>
      </div>
    </section>

    <!-- Citation -->
    <section class="research-section">
      <div class="research-section-intro">
        <span class="kicker">Cite</span>
        <h2>Suggested citation</h2>
      </div>
      <div class="research-section-content">
        <div class="research-cite" data-cite>
          <div class="research-cite-tabs" role="tablist">
            <button class="research-cite-tab active" data-tab="prose"  role="tab" aria-selected="true">Plain</button>
            <button class="research-cite-tab"        data-tab="bibtex" role="tab" aria-selected="false">BibTeX</button>
            <button class="research-cite-tab"        data-tab="apa"    role="tab" aria-selected="false">APA</button>
            <button class="research-copy research-cite-copy" data-copy-target>Copy</button>
          </div>
          <div class="research-cite-panel" data-panel="prose">{citationProse}</div>
          <div class="research-cite-panel" data-panel="bibtex" hidden><pre><code>{citationBibtex}</code></pre></div>
          <div class="research-cite-panel" data-panel="apa" hidden>{citationApa}</div>
        </div>
      </div>
    </section>

  </section>

  <script is:inline>
    // Copy-to-clipboard. Buttons with data-copy use the attribute value;
    // buttons with data-copy-target copy the closest figure/cite block's text.
    (function () {
      function closestText(btn) {
        const fig = btn.closest("figure");
        if (fig) return fig.querySelector("code")?.innerText || "";
        const cite = btn.closest("[data-cite]");
        if (cite) {
          const active = cite.querySelector(".research-cite-panel:not([hidden])");
          return active?.innerText || "";
        }
        return "";
      }
      function flash(btn) {
        const prev = btn.textContent;
        btn.textContent = "Copied";
        btn.classList.add("is-copied");
        setTimeout(() => {
          btn.textContent = prev;
          btn.classList.remove("is-copied");
        }, 1400);
      }
      document.querySelectorAll(".research-copy").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const text = btn.dataset.copy != null
            ? btn.dataset.copy
            : closestText(btn);
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            flash(btn);
          } catch {
            // Older browsers: fall back to execCommand via a temp textarea
            const ta = document.createElement("textarea");
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand("copy"); flash(btn); } catch {}
            document.body.removeChild(ta);
          }
        });
      });

      // Citation tabs
      document.querySelectorAll("[data-cite]").forEach((cite) => {
        const tabs = cite.querySelectorAll(".research-cite-tab");
        const panels = cite.querySelectorAll(".research-cite-panel");
        tabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            tabs.forEach((t) => { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
            tab.classList.add("active");
            tab.setAttribute("aria-selected", "true");
            const target = tab.dataset.tab;
            panels.forEach((p) => {
              if (p.dataset.panel === target) p.removeAttribute("hidden");
              else p.setAttribute("hidden", "");
            });
          });
        });
      });
    })();
  </script>
</Base>
