---
import Base from "../../layouts/Base.astro";
import CitationBox from "../../components/CitationBox.astro";
import parksData from "../../../public/data/parks.json";
import { stripeColor } from "../../lib/stripes";
import { fmtSlope, fmtPVal, fmtTotal, cToF, cDeltaToF } from "../../lib/format";
import { metaFor } from "../../lib/variables";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const idx = (parksData as any).parks as any[];
  return idx.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const base = import.meta.env.BASE_URL;

// Load full summary JSON at build time
const fullPath = path.resolve("public/data/parks", `${slug}.json`);
const summary = JSON.parse(fs.readFileSync(fullPath, "utf-8"));

const title = `${summary.unit_name} — Climate Trends`;
const period = summary.period;

// Convert temperature fields from °C → °F in place before rendering.
// Pipeline data stays SI; this is a display-layer choice for US audiences.
const TEMP_VARS = new Set(["tmean_c", "tmax_c", "tmin_c"]);
const TEMP_FIELDS = ["tmean_c", "tmax_c", "tmin_c"];
for (const row of summary.annual ?? []) {
  for (const f of TEMP_FIELDS) {
    if (row[f] != null) row[f] = cToF(row[f]);
  }
}
for (const s of summary.stripes ?? []) {
  if (s.value != null) s.value = cToF(s.value);
}
const convertTrend = (t: any) => {
  if (!TEMP_VARS.has(t.variable)) return t;
  return {
    ...t,
    slope_per_year: cDeltaToF(t.slope_per_year),
    intercept: t.intercept != null ? cToF(t.intercept) : t.intercept,
  };
};
for (const v of TEMP_FIELDS) {
  if (summary.headline_trends?.[v]) {
    summary.headline_trends[v] = convertTrend({
      variable: v,
      ...summary.headline_trends[v],
    });
  }
}
if (Array.isArray(summary.trends)) {
  summary.trends = summary.trends.map(convertTrend);
}

// Convert decomposition temperatures (°C → °F) in place. Observed,
// trend, and per-period climatology values are absolute temperatures
// so use cToF.
for (const v of TEMP_FIELDS) {
  const d = summary.decomposition?.[v];
  if (!d) continue;
  d.observed = d.observed.map((x: number | null) => x == null ? null : cToF(x));
  d.trend    = d.trend.map((x: number | null) => x == null ? null : cToF(x));
  d.climatology = d.climatology.map((p: any) => ({
    period: p.period,
    values: p.values.map((m: any) => ({ month: m.month, mean: cToF(m.mean) })),
  }));
}

const headline = summary.headline_trends ?? {};
const stripes = summary.stripes ?? [];
const annual = summary.annual ?? [];
const anomalies = summary.anomalies ?? [];
const trends = summary.trends ?? [];

// Pick ordered headline variables
const HEADLINE_ORDER = ["tmean_c", "tmax_c", "tmin_c", "prcp_mm"];
const headlineCards = HEADLINE_ORDER.filter((v) => headline[v]).map((v) => ({
  variable: v,
  ...headline[v],
  meta: metaFor(v),
}));

// Color each chart by variable kind so the time-series strip reads at a glance.
const COLOR_BY_KIND: Record<string, string> = {
  temperature: "#b5613b",
  precip: "#4a7fa5",
  snow: "#2d5a7a",
  other: "#6e6760",
};

// Per-park citation strings — same three formats as the project-wide
// citation on /researchers, but specific to this park.
const repoUrl = "https://github.com/anniebritton/NPS-Open-Climate-Data";
const bibKey = `britton2026nps_${summary.slug.replace(/-/g, "_")}`;
const citationProse = `Britton, A., & Pritchard, I. (2026). ${summary.unit_name} climate series, Open Climate Data — US National Parks. Derived from DAYMET v4 (Thornton et al.) and ERA5-Land (Muñoz-Sabater et al.). ${repoUrl}`;
const citationApa = `Britton, A., & Pritchard, I. (2026). ${summary.unit_name} climate series [Dataset]. Open Climate Data — US National Parks. ${repoUrl}`;
const citationBibtex = `@misc{${bibKey},
  author       = {Britton, Annie and Pritchard, Ian},
  title        = {${summary.unit_name} climate series},
  year         = {2026},
  howpublished = {Open Climate Data --- US National Parks},
  note         = {Derived from DAYMET v4 (Thornton et al.) and
                  ERA5-Land (Mu\\~noz-Sabater et al.)},
  url          = {${repoUrl}}
}`;

// Per-variable overrides for cases where the kind-based default doesn't read
// well. Evapotranspiration variables get a leafy green so they're not
// indistinguishable from radiation/wind on the chart strip.
const COLOR_BY_VARIABLE: Record<string, string> = {
  pet_mm: "#2a6041",
  aet_mm: "#3f7a4a",
};

// One row per trend, ordered: headline vars first (in HEADLINE_ORDER), then the rest.
const trendRows = (() => {
  const inHeadline = (v: string) => HEADLINE_ORDER.includes(v);
  const sorted = [...trends].sort((a: any, b: any) => {
    const ai = HEADLINE_ORDER.indexOf(a.variable);
    const bi = HEADLINE_ORDER.indexOf(b.variable);
    if (inHeadline(a.variable) && inHeadline(b.variable)) return ai - bi;
    if (inHeadline(a.variable)) return -1;
    if (inHeadline(b.variable)) return 1;
    return a.variable.localeCompare(b.variable);
  });
  return sorted.map((t: any) => ({
    ...t,
    meta: metaFor(t.variable),
    color: COLOR_BY_VARIABLE[t.variable]
        ?? COLOR_BY_KIND[metaFor(t.variable).kind]
        ?? COLOR_BY_KIND.other,
  }));
})();
---
<Base title={title} description={`Climate trends for ${summary.unit_name}, ${period.start_year}-${period.end_year}.`}>
  <section class="container section park-section">
    <a href={base} style="font-size:0.9rem;">← All parks</a>
    <span class="kicker" style="margin-top:0.8rem;display:block">{summary.state}</span>
    <h1>{summary.unit_name}</h1>
    <p style="color:var(--ink);max-width:70ch">
      Daily {summary.multipart ? "per-unit" : "park-wide"} climate series
      from <strong>{period.start_year}</strong> to <strong>{period.end_year}</strong>,
      reduced from DAYMET v4 {summary.state.includes("AK") || summary.state === "AS" || summary.state === "VI" ? "/ ERA5-Land" : "+ ERA5-Land"}
      over the real PAD-US 4.1 park boundary.
    </p>

    <div class="map-beside-stripes" style="margin-top:1.4rem">
      <div>
        <div id="map" data-slug={summary.slug}></div>
        <div class="map-hint">Ctrl + scroll to zoom · drag to pan</div>
      </div>
      <div class="stripes-column">
        <div style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted)">
          Annual mean temperature · {period.start_year}–{period.end_year}
        </div>
        <div class="stripes-legend">
          <span><span class="stripes-legend-swatch" style={`background:${stripeColor(-2)}`}></span>Cooler than 1981–2010 baseline</span>
          <span><span class="stripes-legend-swatch" style={`background:${stripeColor(0)}`}></span>Near baseline</span>
          <span><span class="stripes-legend-swatch" style={`background:${stripeColor(2)}`}></span>Warmer than 1981–2010 baseline</span>
        </div>
        <div class="stripes-full">
          {stripes.map((s: any) => (
            <div style={`background:${stripeColor(s.z)}`}
                 data-year={s.year}
                 data-value={s.value != null ? s.value.toFixed(1) : ""}
                 data-z={s.z == null ? "" : s.z.toFixed(2)}></div>
          ))}
          <div id="stripes-tooltip" class="stripes-tooltip" role="tooltip"></div>
        </div>
        <div class="stripes-years">
          <span>{period.start_year}</span><span>{period.end_year}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="container section park-section">
    <h2>Headline trends</h2>
    <p style="color:var(--ink)">
      Theil–Sen slope estimates with Mann–Kendall p-values. Trends marked
      ✓ are statistically significant at the 95% level.
    </p>
    <div class="trend-grid">
      {headlineCards.map((c: any) => (
        <div class={`trend-card ${c.meta.kind === "temperature" ? "" : c.meta.kind === "precip" ? "cool" : ""}`}>
          <div class="var-label">{c.meta.label}</div>
          <div class="slope">
            {fmtSlope(c.slope_per_year, c.meta.decimals)}<span class="unit">{c.meta.slopeUnit}</span>
            {c.significant_95 ? <span class="sig">significant</span> : <span class="sig not-sig">not sig.</span>}
          </div>
          <div class="detail">
            Total {fmtTotal(c.slope_per_year, c.n)}{c.meta.unit.includes("mm") ? " mm" : " °F"} since {c.start_year} · {fmtPVal(c.p_value)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="container section park-section">
    <h2>Time series & trends</h2>
    <p style="color:var(--ink);max-width:70ch">
      Every variable in the dataset, with its Theil–Sen slope and Mann–Kendall
      p-value. <strong>Click any row</strong> to open the annual time
      series, a 12-month rolling trend (long-term direction without the
      annual cycle), and the seasonal climatology overlaid for three
      15-year periods so the shift in seasonal pattern is visible.
    </p>
    <div class="trend-rows" role="list">
      <div class="trend-rows-head" aria-hidden="true">
        <span>Variable</span>
        <span class="num">Slope / yr</span>
        <span class="num">Total change</span>
        <span class="num">p-value</span>
        <span>Significance</span>
        <span class="trend-rows-head-hint">Open chart</span>
      </div>
      {trendRows.map((t: any) => (
        <details class="trend-row" data-var={t.variable} role="listitem">
          <summary aria-label={`Open ${t.meta.label} time-series chart`}>
            <span class="tr-var">{t.meta.label}</span>
            <span class="tr-slope num">
              {fmtSlope(t.slope_per_year, t.meta.decimals)} <span class="tr-unit">{t.meta.slopeUnit}</span>
            </span>
            <span class="tr-total num">{fmtTotal(t.slope_per_year, t.n)}</span>
            <span class="tr-pval num">{fmtPVal(t.p_value)}</span>
            <span class="tr-sig">
              {t.significant_95 ? <span class="sig">sig.</span> : <span class="sig not-sig">not sig.</span>}
            </span>
            <span class="tr-chev" aria-hidden="true">
              <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                <path d="M3 6 L8 11 L13 6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </summary>
          <div class="trend-row-body">
            {t.meta.description ? <p class="tr-desc">{t.meta.description}</p> : null}
            <div class="chart-actions">
              <button type="button" class="chart-download" data-download-var={t.variable}
                      data-download-slug={summary.slug}>
                Download all charts (PNG)
              </button>
            </div>
            <div class="chart-wrap">
              <div class="title">
                <span>
                  Annual {t.meta.label.toLowerCase()} ({t.meta.unit})
                  <span class="theil-tag">(Theil–Sen)</span>
                </span>
              </div>
              <div class="chart-canvas"><canvas id={`chart-${t.variable}`}></canvas></div>
            </div>
            {summary.decomposition?.[t.variable] ? (
              <div class="decomp-grid">
                <div class="chart-wrap">
                  <div class="title">
                    <span>Long-term trend (12-month rolling)</span>
                  </div>
                  <div class="chart-canvas"><canvas id={`chart-decomp-trend-${t.variable}`}></canvas></div>
                </div>
                <div class="chart-wrap">
                  <div class="title">
                    <span>Seasonal cycle by period</span>
                  </div>
                  <div class="chart-canvas"><canvas id={`chart-decomp-clim-${t.variable}`}></canvas></div>
                </div>
              </div>
            ) : null}
          </div>
        </details>
      ))}
    </div>
  </section>

  <section class="container section park-section">
    <h2>Download the data</h2>
    <p style="color:var(--ink)">
      Everything on this page is open-licensed. The summary JSON is
      served directly; the daily raw CSVs (~2 MB gzipped each) are too
      large to commit to the repo — for now, run the EE pipeline
      locally via <code>pipeline.ipynb</code>.
    </p>
    <div class="downloads">
      <a href={`${base}data/parks/${summary.slug}.json`} download>Summary JSON</a>
      <a href={`${base}data/boundaries/${summary.slug}.geojson`} download>Boundary GeoJSON</a>
    </div>
    <h3 style="margin-top:1.4rem">Cite this park</h3>
    <CitationBox prose={citationProse} bibtex={citationBibtex} apa={citationApa} />
  </section>

  <script define:vars={{ slug, annual, headline, trends, trendRows, base }} is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script define:vars={{ summary, trendRows, base }}>
    // chartInstances[variable] is { annual, trend, clim } so the download
    // button can grab all three Chart.js instances for that row.
    const chartInstances = {};
    function lineChart(id, years, values, label, color, trend, decimals) {
      const ctx = document.getElementById(id);
      if (!ctx) return null;
      const datasets = [{
        label,
        data: values,
        borderColor: color,
        backgroundColor: color + "22",
        tension: 0.15,
        pointRadius: 3.2,
        pointHoverRadius: 5,
        fill: true,
      }];
      if (trend && trend.slope_per_year != null && trend.intercept != null) {
        const slope = trend.slope_per_year;
        const intercept = trend.intercept;
        const trendY = years.map((y) => slope * y + intercept);
        const d = decimals ?? 3;
        datasets.push({
          label: `Theil–Sen trend (${slope >= 0 ? "+" : ""}${slope.toFixed(d)}/yr)`,
          data: trendY,
          borderColor: "#0d0d0c",
          borderDash: [6, 4],
          pointRadius: 0,
          fill: false,
        });
      }
      const chart = new Chart(ctx, {
        type: "line",
        data: { labels: years, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: "bottom" } },
          scales: {
            y: { beginAtZero: false, grid: { color: "rgba(26,26,26,0.08)" } },
            x: { grid: { display: false } },
          },
        },
      });
      return chart;
    }

    // Build per-variable chart configs once, then lazy-init on first <details> open.
    // Avoids creating ~14 Chart.js instances per park up front.
    const years = summary.annual.map((r) => r.year);
    const chartConfigs = {};
    for (const t of trendRows) {
      const values = summary.annual.map((r) => r[t.variable]);
      chartConfigs[t.variable] = {
        values,
        label: `${t.meta.label} (${t.meta.unit})`,
        color: t.color,
        trend: t,
        decimals: t.meta.decimals,
      };
    }
    // For every accordion row: lazy-init the annual chart, the
    // 12-month-rolling decomposition trend chart, and the seasonal
    // climatology chart on first open. Three Chart.js instances per
    // variable when the row is opened; nothing built until then.
    const monthNames = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    function decompTrendChart(id, decomp, color, unit) {
      const ctx = document.getElementById(id);
      if (!ctx) return null;
      const fade = color.startsWith("#") ? color + "55" : color;
      new Chart(ctx, {
        type: "line",
        data: {
          labels: decomp.months,
          datasets: [
            {
              label: `Monthly (${unit})`,
              data: decomp.observed,
              borderColor: fade,
              backgroundColor: "rgba(0,0,0,0.04)",
              pointRadius: 0,
              borderWidth: 1,
              fill: false,
            },
            {
              label: `12-mo rolling trend (${unit})`,
              data: decomp.trend,
              borderColor: color,
              pointRadius: 0,
              borderWidth: 2.4,
              tension: 0.2,
              fill: false,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: { legend: { position: "bottom" } },
          scales: {
            y: { beginAtZero: false, grid: { color: "rgba(26,26,26,0.08)" }, title: { display: true, text: unit } },
            x: {
              grid: { display: false },
              ticks: {
                // Year-only labels (skip everything except January), and
                // let Chart.js drop labels until they fit. autoSkip with
                // a generous maxTicksLimit prevents the year strings
                // from overlapping on narrow viewports.
                callback: function (val) {
                  const lbl = this.getLabelForValue(val);
                  return lbl && lbl.endsWith("-01") ? lbl.slice(0, 4) : "";
                },
                autoSkip: true,
                maxTicksLimit: 10,
                maxRotation: 0,
                minRotation: 0,
              },
            },
          },
        },
      });
    }
    function decompClimChart(id, decomp, color, unit) {
      const ctx = document.getElementById(id);
      if (!ctx) return;
      const periods = decomp.climatology;
      if (!periods || !periods.length) return;
      const labels = periods[0].values.map((m) => monthNames[m.month - 1]);

      // Color-grade the periods oldest → newest. Newest is the
      // variable's accent color; older periods step through clearly
      // distinct grays (light → mid) instead of two near-identical
      // tans, so the three lines actually read apart from each other.
      const muted = ["#cfccc4", "#6e6760"];  // older → mid (light gray, mid gray)
      const colors = periods.map((_, i) =>
        i === periods.length - 1 ? color : (muted[i] ?? muted[muted.length - 1])
      );
      const widths = periods.map((_, i) =>
        i === periods.length - 1 ? 2.6 : 1.8
      );
      const datasets = periods.map((p, i) => ({
        label: `${p.period[0]}–${p.period[1]}`,
        data: p.values.map((m) => m.mean),
        borderColor: colors[i],
        backgroundColor: "rgba(0,0,0,0)",
        pointRadius: i === periods.length - 1 ? 3 : 0,
        pointHoverRadius: 5,
        borderWidth: widths[i],
        tension: 0.3,
        fill: false,
      }));

      return new Chart(ctx, {
        type: "line",
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: { legend: { position: "bottom" } },
          scales: {
            y: { beginAtZero: false, grid: { color: "rgba(26,26,26,0.08)" }, title: { display: true, text: unit } },
            x: { grid: { display: false } },
          },
        },
      });
    }

    const initialized = new Set();
    document.querySelectorAll("details.trend-row").forEach((det) => {
      det.addEventListener("toggle", () => {
        if (!det.open) return;
        const key = det.dataset.var;
        if (initialized.has(key)) return;
        initialized.add(key);
        chartInstances[key] = chartInstances[key] || {};
        const cfg = chartConfigs[key];
        if (cfg) {
          const chart = lineChart(`chart-${key}`, years, cfg.values, cfg.label, cfg.color, cfg.trend, cfg.decimals);
          if (chart) chartInstances[key].annual = chart;
        }
        const decomp = summary.decomposition && summary.decomposition[key];
        if (decomp) {
          const color = cfg ? cfg.color : "#6e6760";
          // For temperature variables the decomposition was converted
          // °C → °F server-side, so the unit shown on the axis matches.
          const unit = (cfg && cfg.label.match(/\(([^)]+)\)$/)) ? cfg.label.match(/\(([^)]+)\)$/)[1] : "";
          const trendChart = decompTrendChart(`chart-decomp-trend-${key}`, decomp, color, unit);
          const climChart  = decompClimChart(`chart-decomp-clim-${key}`,  decomp, color, unit);
          if (trendChart) chartInstances[key].trend = trendChart;
          if (climChart)  chartInstances[key].clim  = climChart;
        }
      });
    });

    // Download all chart PNGs for a single variable. The button lives
    // inside the accordion body, so by the time it's clickable the row
    // is open and the three Chart.js instances exist.
    function triggerDownload(url, filename) {
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
    }
    document.querySelectorAll(".chart-download").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const key = btn.dataset.downloadVar;
        const slug = btn.dataset.downloadSlug || "park";
        const charts = chartInstances[key];
        if (!charts) return;
        // Three downloads, one per chart type. Browsers stagger with a
        // small delay so they don't get suppressed as a single batch.
        const drops = [
          { chart: charts.annual, suffix: "annual" },
          { chart: charts.trend,  suffix: "trend"  },
          { chart: charts.clim,   suffix: "seasonal" },
        ].filter((d) => d.chart);
        drops.forEach((d, i) => {
          setTimeout(() => {
            triggerDownload(
              d.chart.toBase64Image("image/png", 1),
              `${slug}_${key}_${d.suffix}.png`,
            );
          }, i * 120);
        });
      });
    });

    // Climate-stripes hover tooltip — replaces the native title-attribute
    // tooltip with a cursor-following overlay (year + value + z-score).
    (function () {
      const strip = document.querySelector(".stripes-full");
      const tip = document.getElementById("stripes-tooltip");
      if (!strip || !tip) return;
      strip.addEventListener("mousemove", (e) => {
        const cell = e.target.closest("[data-year]");
        if (!cell) { tip.classList.remove("active"); return; }
        const rect = strip.getBoundingClientRect();
        const year = cell.dataset.year;
        const val = cell.dataset.value;
        const z = cell.dataset.z;
        tip.innerHTML = `<strong>${year}</strong>` +
          `<span>${val ? `${val} °F` : "no data"}${z ? ` &middot; z = ${z}` : ""}</span>`;
        tip.style.left = (e.clientX - rect.left) + "px";
        tip.style.top = (e.clientY - rect.top) + "px";
        tip.classList.add("active");
      });
      strip.addEventListener("mouseleave", () => tip.classList.remove("active"));
    })();

    // map — single park view with a fill shaded by its own warming slope.
    const mapEl = document.getElementById("map");
    if (mapEl) {
      const map = L.map(mapEl, { scrollWheelZoom: false }).setView([39.5, -98.5], 3);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 14,
      }).addTo(map);

      mapEl.addEventListener("wheel", (e) => {
        if (!(e.ctrlKey || e.metaKey)) return;
        e.preventDefault();
        if (e.deltaY < 0) map.zoomIn(1, { animate: true });
        else if (e.deltaY > 0) map.zoomOut(1, { animate: true });
      }, { passive: false });

      // Neutral boundary styling everywhere on the site: muted fill,
      // crisp dark outline. The map is a locator, not a data viz.
      const NEUTRAL_FILL = "#c9c3b0";
      const BOUNDARY_STROKE = "#1e1e1e";

      fetch(`${base}data/boundaries/${summary.slug}.geojson`)
        .then((r) => (r.ok ? r.json() : null))
        .then((geo) => {
          if (!geo) {
            mapEl.innerHTML = '<div style="padding:1rem;color:var(--muted)">Boundary GeoJSON not bundled yet; see GitHub for full boundaries.</div>';
            return;
          }
          const layer = L.geoJSON(geo, {
            style: () => ({
              color: BOUNDARY_STROKE,
              weight: 1.5,
              fillColor: NEUTRAL_FILL,
              fillOpacity: 0.5,
            }),
          }).addTo(map);
          map.fitBounds(layer.getBounds(), { padding: [20, 20] });
        });
    }
  </script>
</Base>
