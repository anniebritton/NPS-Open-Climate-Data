---
import Base from "../../layouts/Base.astro";
import parksData from "../../../public/data/parks.json";
import { stripeColor } from "../../lib/stripes";
import { fmtSlope, fmtPVal, fmtTotal } from "../../lib/format";
import { metaFor } from "../../lib/variables";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const idx = (parksData as any).parks as any[];
  return idx.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const base = import.meta.env.BASE_URL;

// Load full summary JSON at build time
const fullPath = path.resolve("public/data/parks", `${slug}.json`);
const summary = JSON.parse(fs.readFileSync(fullPath, "utf-8"));

const title = `${summary.unit_name} — Climate Trends`;
const period = summary.period;
const headline = summary.headline_trends ?? {};
const stripes = summary.stripes ?? [];
const annual = summary.annual ?? [];
const anomalies = summary.anomalies ?? [];
const trends = summary.trends ?? [];

// Pick ordered headline variables
const HEADLINE_ORDER = ["tmean_c", "tmax_c", "tmin_c", "prcp_mm"];
const headlineCards = HEADLINE_ORDER.filter((v) => headline[v]).map((v) => ({
  variable: v,
  ...headline[v],
  meta: metaFor(v),
}));

// Secondary trends (anything non-headline)
const secondaryTrends = trends.filter((t: any) => !HEADLINE_ORDER.includes(t.variable));
---
<Base title={title} description={`Climate trends for ${summary.unit_name}, ${period.start_year}-${period.end_year}.`}>
  <section class="container section">
    <a href={base} style="font-size:0.9rem;">← All parks</a>
    <span class="kicker" style="margin-top:0.8rem;display:block">{summary.state}</span>
    <h1>{summary.unit_name}</h1>
    <p style="color:var(--muted);max-width:680px">
      Daily {summary.multipart ? "per-unit" : "park-wide"} climate series
      from <strong>{period.start_year}</strong> to <strong>{period.end_year}</strong>,
      reduced from DAYMET v4 {summary.state.includes("AK") || summary.state === "AS" || summary.state === "VI" ? "/ ERA5-Land" : "+ ERA5-Land"}
      over the park boundary (USGS PAD-US v20).
    </p>

    <div class="stripes-full" title="Annual mean temperature anomaly, 1981-2010 baseline">
      {stripes.map((s: any) => <div style={`background:${stripeColor(s.z)}`} title={`${s.year}: ${s.value.toFixed(2)}°C (z=${s.z == null ? "—" : s.z.toFixed(2)})`}></div>)}
    </div>
    <div style="display:flex;justify-content:space-between;color:var(--muted);font-size:0.82rem;">
      <span>{period.start_year}</span>
      <span style="font-style:italic">Climate stripes · annual mean temperature, 1981–2010 baseline</span>
      <span>{period.end_year}</span>
    </div>
  </section>

  <section class="container section">
    <h2>Headline trends</h2>
    <p style="color:var(--muted)">
      Theil–Sen slope estimates with Mann–Kendall p-values. Trends marked
      ✓ are statistically significant at the 95% level.
    </p>
    <div class="trend-grid">
      {headlineCards.map((c: any) => (
        <div class={`trend-card ${c.meta.kind === "temperature" ? "" : c.meta.kind === "precip" ? "cool" : ""}`}>
          <div class="var-label">{c.meta.label}</div>
          <div class="slope">
            {fmtSlope(c.slope_per_year, c.meta.decimals)}<span class="unit">{c.meta.slopeUnit}</span>
            {c.significant_95 ? <span class="sig">significant</span> : <span class="sig not-sig">not sig.</span>}
          </div>
          <div class="detail">
            Total {fmtTotal(c.slope_per_year, c.n)}{c.meta.unit.includes("mm") ? " mm" : "°C"} since {c.start_year} · {fmtPVal(c.p_value)}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="container section">
    <h2>Time series</h2>
    <div class="chart-wrap">
      <div class="title">Annual mean temperature (°C) + Theil–Sen trend</div>
      <canvas id="chart-tmean" height="260"></canvas>
    </div>
    <div class="chart-wrap">
      <div class="title">Annual precipitation (mm)</div>
      <canvas id="chart-prcp" height="220"></canvas>
    </div>
    {annual[0]?.swe_mm !== undefined ? (
      <div class="chart-wrap">
        <div class="title">Mean daily snow-water equivalent (mm)</div>
        <canvas id="chart-swe" height="200"></canvas>
      </div>
    ) : null}
  </section>

  {secondaryTrends.length > 0 ? (
    <section class="container section">
      <h2>All variables</h2>
      <table class="data">
        <thead>
          <tr>
            <th>Variable</th><th>Slope / yr</th><th>Total change</th><th>n years</th><th>p-value</th><th></th>
          </tr>
        </thead>
        <tbody>
          {trends.map((t: any) => {
            const meta = metaFor(t.variable);
            return (
              <tr>
                <td>{meta.label}</td>
                <td>{fmtSlope(t.slope_per_year, meta.decimals)} {meta.slopeUnit}</td>
                <td>{fmtTotal(t.slope_per_year, t.n)}</td>
                <td>{t.n}</td>
                <td>{fmtPVal(t.p_value)}</td>
                <td>{t.significant_95 ? <span class="sig">sig.</span> : <span class="sig not-sig">not sig.</span>}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  ) : null}

  <section class="container section">
    <h2>Park boundary &amp; climate stripes</h2>
    <p style="color:var(--muted);max-width:720px">
      The park outline on the left, annual warming/cooling pattern on the
      right. {summary.multipart ? "Sub-units of this park are drawn in distinct shades." : ""}
      Polygon shown is approximate until the full PAD-US export runs — exact
      geometry is in the <a href="https://github.com/anniebritton/NPS-Open-Climate-Data/releases">GitHub release</a>.
    </p>
    <div class="map-beside-stripes">
      <div id="map" data-slug={summary.slug}></div>
      <div class="stripes-column">
        <div style="font-size:0.82rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted)">
          Annual mean temperature · {period.start_year}–{period.end_year}
        </div>
        <div class="stripes-full">
          {stripes.map((s: any) => <div style={`background:${stripeColor(s.z)}`} title={`${s.year}: ${s.value.toFixed(2)}°C (z=${s.z == null ? "—" : s.z.toFixed(2)})`}></div>)}
        </div>
        <div style="display:flex;justify-content:space-between;color:var(--muted);font-size:0.78rem">
          <span>{period.start_year}</span><span>{period.end_year}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="container section">
    <h2>Download the data</h2>
    <p style="color:var(--muted)">
      Daily raw series (1980–{period.end_year}) and analysis summary, all open-licensed.
    </p>
    <div class="downloads">
      <a href={`${base}data/raw/${summary.slug}/${summary.slug}.csv.gz`} download>Daily CSV (gzip)</a>
      <a href={`${base}data/parks/${summary.slug}.json`} download>Summary JSON</a>
      {summary.multipart && summary.parts.map((p: string) => (
        <a href={`${base}data/raw/${summary.slug}/${summary.slug}_${p}.csv.gz`} download>CSV · {p}</a>
      ))}
    </div>
    <p style="color:var(--muted);font-size:0.82rem;margin-top:0.4rem">
      Parquet downloads and full boundary GeoJSON are attached to the
      <a href="https://github.com/anniebritton/NPS-Open-Climate-Data/releases">GitHub release</a>.
    </p>
    <p style="color:var(--muted);font-size:0.88rem;margin-top:1rem">
      Citation: {summary.unit_name} climate series, NPS Open Climate Data,
      derived from DAYMET v4 (Thornton et al.) and ERA5-Land (Muñoz-Sabater et al.).
    </p>
  </section>

  <script define:vars={{ slug, annual, headline, trends, base }} is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.js"></script>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script define:vars={{ summary, base }}>
    // charts
    function lineChart(id, years, values, label, color, trend) {
      const ctx = document.getElementById(id);
      if (!ctx) return;
      const datasets = [{
        label,
        data: values,
        borderColor: color,
        backgroundColor: color + "22",
        tension: 0.15,
        pointRadius: 2,
        fill: true,
      }];
      if (trend) {
        const slope = trend.slope_per_year;
        const intercept = trend.intercept;
        const trendY = years.map((y) => slope * y + intercept);
        datasets.push({
          label: `Theil–Sen trend (${slope >= 0 ? "+" : ""}${slope.toFixed(3)}/yr)`,
          data: trendY,
          borderColor: "#0d0d0c",
          borderDash: [6, 4],
          pointRadius: 0,
          fill: false,
        });
      }
      new Chart(ctx, {
        type: "line",
        data: { labels: years, datasets },
        options: {
          responsive: true,
          plugins: { legend: { position: "bottom" } },
          scales: {
            y: { beginAtZero: false, grid: { color: "rgba(26,26,26,0.08)" } },
            x: { grid: { display: false } },
          },
        },
      });
    }

    const years = summary.annual.map((r) => r.year);
    lineChart("chart-tmean", years, summary.annual.map((r) => r.tmean_c), "Mean temp (°C)", "#b5613b", summary.headline_trends?.tmean_c);
    lineChart("chart-prcp", years, summary.annual.map((r) => r.prcp_mm), "Precip (mm)", "#4a7fa5", summary.headline_trends?.prcp_mm);
    if (summary.annual[0]?.swe_mm !== undefined) {
      lineChart("chart-swe", years, summary.annual.map((r) => r.swe_mm), "SWE (mm)", "#2d5a7a", null);
    }

    // map — single park view with a fill shaded by its own warming slope.
    const mapEl = document.getElementById("map");
    if (mapEl) {
      const map = L.map(mapEl).setView([39.5, -98.5], 3);
      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 14,
      }).addTo(map);

      const slope = summary.headline_trends?.tmean_c?.slope_per_year ?? null;
      const warmFill = (() => {
        if (slope == null) return "#c9c3b0";
        const v = Math.max(-0.04, Math.min(0.04, slope)) / 0.04;
        if (v >= 0) {
          const t = v;
          const r = Math.round(240 + (77 - 240) * t);
          const g = Math.round(227 + (38 - 227) * t);
          const b = Math.round(211 + (35 - 211) * t);
          return `rgb(${r},${g},${b})`;
        }
        const t = -v;
        const r = Math.round(240 + (61 - 240) * t);
        const g = Math.round(227 + (97 - 227) * t);
        const b = Math.round(211 + (137 - 211) * t);
        return `rgb(${r},${g},${b})`;
      })();

      fetch(`${base}data/boundaries/${summary.slug}.geojson`)
        .then((r) => (r.ok ? r.json() : null))
        .then((geo) => {
          if (!geo) {
            mapEl.innerHTML = '<div style="padding:1rem;color:var(--muted)">Boundary GeoJSON not bundled yet; see GitHub for full boundaries.</div>';
            return;
          }
          // For multipart parks, vary fill lightness so sub-units read as distinct.
          let idx = 0;
          const subShades = ["#2a6041", "#b5613b", "#4a7fa5", "#7a3c20", "#8ab5d4"];
          const layer = L.geoJSON(geo, {
            style: () => {
              const style = summary.multipart
                ? { color: "#0d0d0c", weight: 1.5, fillColor: subShades[idx % subShades.length], fillOpacity: 0.55 }
                : { color: "#0d0d0c", weight: 1.5, fillColor: warmFill, fillOpacity: 0.8 };
              idx += 1;
              return style;
            },
          }).addTo(map);
          map.fitBounds(layer.getBounds(), { padding: [20, 20] });
        });
    }
  </script>
</Base>
