---
import Base from "../layouts/Base.astro";
import parksData from "../../public/data/parks.json";
import { stripeColor } from "../lib/stripes";
import { fmtSlope, cDeltaToF } from "../lib/format";
import { silhouetteFromGeoJSON } from "../lib/silhouette";
import fs from "node:fs";
import path from "node:path";

const base = import.meta.env.BASE_URL;
const parks = parksData.parks as any[];

// Pre-compute a tiny SVG silhouette path per park from the boundary GeoJSON.
// When real PAD-US polygons replace the current circular approximations, the
// silhouettes automatically become distinctive — no code change.
function loadSilhouette(slug: string): string {
  try {
    const geo = JSON.parse(
      fs.readFileSync(path.resolve("public/data/boundaries", `${slug}.geojson`), "utf-8"),
    );
    const g = geo.features?.[0]?.geometry;
    return g ? silhouetteFromGeoJSON(g) : "";
  } catch {
    return "";
  }
}

// Climate-stripes color bar for each park uses its tmean z-scores
const withStripes = parks.map((p) => {
  const stripes = (p.stripes ?? []).map((s: any) => stripeColor(s.z));
  return { ...p, stripeColors: stripes, silhouette: loadSilhouette(p.slug) };
});

// Aggregate headline stat: average total temperature change across all
// parks since each park's record began (~1980). Slope × (n_years − 1)
// is precomputed as `total_change` in the pipeline JSON. Expressed as
// a full-record delta instead of a per-year slope, the number is more
// tangible — "+2.7 °F since 1980" beats "+0.06 °F per year" for a
// general audience.
const totalChangesC = parks
  .map((p) => p.headline_trends?.tmean_c?.total_change)
  .filter((v): v is number => typeof v === "number");
const meanTotalChangeC = totalChangesC.reduce((a, b) => a + b, 0) / (totalChangesC.length || 1);
const meanTotalChangeF = cDeltaToF(meanTotalChangeC) ?? 0;
const warmingParks = parks.filter(
  (p) => (p.headline_trends?.tmean_c?.significant_95 ?? false) && p.headline_trends.tmean_c.slope_per_year > 0,
).length;
const startYear = Math.min(...parks.map((p) => p.period?.start_year ?? 1980));
const endYear = Math.max(...parks.map((p) => p.period?.end_year ?? 2024));

// 2-letter state codes in parks.json → full names, so card search accepts
// either "UT" or "Utah". Multi-state parks (e.g. "CA,NV") are expanded.
const STATE_NAMES: Record<string, string> = {
  AK: "Alaska", AL: "Alabama", AR: "Arkansas", AS: "American Samoa",
  AZ: "Arizona", CA: "California", CO: "Colorado", CT: "Connecticut",
  DE: "Delaware", FL: "Florida", GA: "Georgia", HI: "Hawaii",
  IA: "Iowa", ID: "Idaho", IL: "Illinois", IN: "Indiana",
  KS: "Kansas", KY: "Kentucky", LA: "Louisiana", MA: "Massachusetts",
  MD: "Maryland", ME: "Maine", MI: "Michigan", MN: "Minnesota",
  MO: "Missouri", MS: "Mississippi", MT: "Montana", NC: "North Carolina",
  ND: "North Dakota", NE: "Nebraska", NH: "New Hampshire", NJ: "New Jersey",
  NM: "New Mexico", NV: "Nevada", NY: "New York", OH: "Ohio",
  OK: "Oklahoma", OR: "Oregon", PA: "Pennsylvania", PR: "Puerto Rico",
  RI: "Rhode Island", SC: "South Carolina", SD: "South Dakota", TN: "Tennessee",
  TX: "Texas", UT: "Utah", VA: "Virginia", VI: "Virgin Islands",
  VT: "Vermont", WA: "Washington", WI: "Wisconsin", WV: "West Virginia",
  WY: "Wyoming",
};
function stateSearchKey(code: string): string {
  // "CA,NV" → "ca nv california nevada"
  const codes = code.split(/[,/]/).map((s) => s.trim()).filter(Boolean);
  const words = codes.flatMap((c) => [c.toLowerCase(), (STATE_NAMES[c] || "").toLowerCase()]);
  return words.filter(Boolean).join(" ");
}

// Group each park into a coarse region for the Browse-the-parks filter
// chips and the regional strip chart. Multi-state parks (e.g. "CA,NV")
// use their first state.
const STATE_TO_REGION: Record<string, string> = {
  AK: "Alaska",
  WA: "Pacific NW", OR: "Pacific NW",
  CA: "California",
  AZ: "Southwest", UT: "Southwest", NV: "Southwest", NM: "Southwest", TX: "Southwest",
  MT: "Rockies", WY: "Rockies", ID: "Rockies", CO: "Rockies", SD: "Rockies", ND: "Rockies",
  NE: "Midwest", KS: "Midwest", MO: "Midwest", AR: "Midwest",
  MN: "Midwest", MI: "Midwest", OH: "Midwest", IN: "Midwest",
  ME: "East", VA: "East", WV: "East", MD: "East",
  KY: "East", TN: "East", NC: "East", SC: "East", GA: "East", FL: "East",
  HI: "Tropical", AS: "Tropical", VI: "Tropical", PR: "Tropical",
};
const REGION_ORDER = ["Alaska", "Pacific NW", "California", "Rockies", "Southwest", "Midwest", "East", "Tropical"];
function regionFor(stateCode: string): string {
  const first = stateCode.split(/[,/]/)[0].trim();
  return STATE_TO_REGION[first] ?? "Other";
}

// Data for the regional strip chart. Every US National Park in the
// record warmed, so a slope-based ±axis wastes half its width on an
// empty cooling side. Use total °F change instead (matches the headline
// stat) and scale the axis to the actual data range, rounded up to the
// next whole degree.
const parkSwarm = parks.map((p) => ({
  slug: p.slug,
  unit_name: p.unit_name,
  state: p.state,
  region: regionFor(p.state ?? ""),
  totalF: cDeltaToF(p.headline_trends?.tmean_c?.total_change) ?? null,
  sig: p.headline_trends?.tmean_c?.significant_95 ?? false,
})).filter((x) => x.totalF != null) as { slug: string; unit_name: string; state: string; region: string; totalF: number; sig: boolean }[];
const swarmMaxF = Math.max(1, Math.ceil(Math.max(...parkSwarm.map((p) => p.totalF))));
const swarmMinF = Math.min(0, Math.floor(Math.min(...parkSwarm.map((p) => p.totalF))));

// Turn a park's annual temperature series (stored on stripes[].value in °C)
// into a compact SVG path for a 120×36 mini sparkline. The sparkline
// reveals on card hover; the stripes row collapses beneath it.
function sparklinePath(series: { value: number | null }[]): string {
  const vals = series.map((s) => s.value).filter((v): v is number => v != null);
  if (vals.length < 2) return "";
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const range = max - min || 1;
  const n = series.length;
  let path = "";
  let started = false;
  series.forEach((s, i) => {
    if (s.value == null) return;
    const x = (i / (n - 1)) * 120;
    const y = 32 - ((s.value - min) / range) * 28;
    path += (started ? "L" : "M") + x.toFixed(1) + "," + y.toFixed(1) + " ";
    started = true;
  });
  return path.trim();
}
---
<Base title="Open Climate Data — Climate Trends in US National Parks">
  <section class="hero">
    <div class="hero-upper">
      <!-- Mountain ridge outline. Four parallel lines give depth; bottom      -->
      <!-- endpoints sit at y=380 so the ridge base aligns with the stats     -->
      <!-- divider line below.                                                 -->
      <svg class="hero-mountain" viewBox="0 0 760 380"
           preserveAspectRatio="xMaxYMax meet"
           width="100%" height="100%"
           fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <path id="ridge" d="M 0,380
            C 38,322 72,302 104,285
            C 128,273 142,278 158,286
            C 180,295 198,278 222,258
            C 244,244 258,250 272,254
            C 296,258 314,240 338,212
            C 356,196 370,184 388,168
            C 406,150 422,138 440,124
            C 455,114 470,108 486,98
            C 499,90 514,84 530,80
            C 544,78 558,80 572,86
            C 584,92 594,100 608,112
            C 624,126 636,138 652,152
            C 668,166 682,180 700,196
            C 718,212 732,228 748,248
            C 754,258 757,265 760,380"/>
        </defs>
        <use href="#ridge" stroke="#2a6041" stroke-width="1.4" stroke-opacity="0.60" fill="none"/>
        <use href="#ridge" transform="translate(0,40)" stroke="#2a6041" stroke-width="1.0" stroke-opacity="0.34" fill="none"/>
        <use href="#ridge" transform="translate(0,76)" stroke="#2a6041" stroke-width="0.8" stroke-opacity="0.20" fill="none"/>
        <use href="#ridge" transform="translate(0,108)" stroke="#2a6041" stroke-width="0.7" stroke-opacity="0.11" fill="none"/>
      </svg>
      <div class="hero-content">
        <span class="kicker">Open Climate Data · Since 1980</span>
        <h1>The story of climate<br/>change, park by park</h1>
        <p>
          Every one of the 63 US National Parks, with its own daily record of
          temperature, precipitation, snowpack, evaporation, solar radiation, and wind
          — reduced from reanalysis data, tested for statistical trends,
          and ready to download.
        </p>
        <div class="hero-cta">
          <a href={`${base}#parks`} class="btn btn-filled">Explore Parks</a>
          <a href={`${base}researchers`} class="btn">Download Data</a>
        </div>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="num">{parks.length}</span><span class="lbl">Parks</span></div>
      <div class="stat"><span class="num">{endYear - startYear + 1}</span><span class="lbl">Years of data</span></div>
      <div class="stat"><span class="num">+{meanTotalChangeF.toFixed(1)}°F</span><span class="lbl">Average warming since {startYear}</span></div>
      <div class="stat"><span class="num">{warmingParks}</span><span class="lbl">Parks with significant warming</span></div>
    </div>
  </section>

  <section class="container section" id="map-overview">
    <span class="kicker">Warming at a glance</span>
    <h2>Every park on the map — see each one's warming below</h2>
    <p style="color:var(--muted);max-width:720px">
      All 63 National Parks with their real PAD-US boundaries. Hover a
      park for its warming rate; click to open the full time series.
    </p>
    <div id="overview-map" style="height:520px"></div>

    <div class="swarm-wrap">
      <span class="kicker" style="display:block;margin-bottom:0.35rem">
        Total warming per park, {startYear}–{endYear}
      </span>
      <p style="color:var(--muted);font-size:0.85rem;max-width:640px;margin-bottom:1rem">
        Every park, positioned by its total temperature change since {startYear}
        and grouped by region so you can compare Alaska to the Southwest at a
        glance. Hover for details, click to open.
      </p>
      <div class="swarm-legend">
        <div class="swarm-legend-block">
          <span class="swarm-legend-label">Total warming</span>
          <div class="swarm-legend-bar" aria-hidden="true"></div>
          <div class="swarm-legend-ticks">
            <span>{swarmMinF === 0 ? "0" : `+${swarmMinF}`}°F</span>
            <span>+{swarmMaxF}°F</span>
          </div>
        </div>
        <div class="swarm-legend-block">
          <span class="swarm-legend-label">Significance</span>
          <div class="swarm-legend-sig">
            <span class="swarm-legend-ex sig">Significant</span>
            <span class="swarm-legend-ex not-sig">Not significant</span>
          </div>
        </div>
      </div>
      <div class="swarm">
        <div class="swarm-axis-label">°F since {startYear}</div>
        <div class="swarm-axis" id="swarm-axis"></div>
        <svg id="swarm-svg" viewBox="0 0 1000 500" preserveAspectRatio="xMidYMid meet"
             width="100%" height="500"></svg>
        <div id="swarm-tooltip" class="swarm-tooltip" role="tooltip"></div>
      </div>
    </div>
  </section>

  <section class="container section" id="parks">
    <span class="kicker">All 63 parks</span>
    <h2>Browse the parks</h2>
    <p style="color:var(--muted);max-width:680px">
      Each tile summarises a park's mean annual temperature since {startYear}
      as climate stripes (cool blue = below 1981-2010 baseline, warm red =
      above). Click through for the full time series and trend tests.
    </p>

    <div class="controls">
      <input id="search" type="search" placeholder="Search parks (name or state)…" autocomplete="off" />
      <select id="sort">
        <option value="name">Sort: by name</option>
        <option value="warming">Sort: most warming</option>
        <option value="cooling">Sort: least warming</option>
        <option value="wetter">Sort: getting wetter</option>
        <option value="drier">Sort: getting drier</option>
      </select>
      <label class="toggle-chip">
        <input id="sig-only" type="checkbox" />
        <span>Significant warming only</span>
      </label>
      <span id="result-count" style="color:var(--muted);font-size:0.9rem"></span>
    </div>
    <div class="region-chips" role="group" aria-label="Filter by region">
      <button class="chip active" data-region="all">All parks</button>
      {REGION_ORDER.map((r) => (
        <button class="chip" data-region={r}>{r}</button>
      ))}
    </div>

    <div id="park-grid" class="grid">
      {withStripes.map((p) => {
        const totalC = p.headline_trends?.tmean_c?.total_change ?? null;
        const totalF = cDeltaToF(totalC);
        const slope = cDeltaToF(p.headline_trends?.tmean_c?.slope_per_year);
        const psig = p.headline_trends?.tmean_c?.significant_95 ?? false;
        const wetSlope = p.headline_trends?.prcp_mm?.slope_per_year ?? null;
        const region = regionFor(p.state ?? "");
        const sparkD = sparklinePath(p.stripes ?? []);
        return (
          <a
            class="card park-card"
            href={`${base}parks/${p.slug}`}
            data-name={p.unit_name.toLowerCase()}
            data-state={stateSearchKey(p.state ?? "")}
            data-region={region}
            data-total={totalF ?? 0}
            data-slope={slope ?? 0}
            data-prcp-slope={wetSlope ?? 0}
            data-sig={psig ? "1" : "0"}
          >
            <div class="park-card-top">
              <span class="park-state">{p.state}</span>
              <span class="park-name">{p.unit_name.replace(" National Park", "")}</span>
            </div>
            {p.silhouette ? (
              <svg class="park-silhouette" viewBox="0 0 100 46" aria-hidden="true">
                <path d={p.silhouette}
                      fill="var(--muted)" fill-opacity="0.3"
                      stroke="var(--ink)" stroke-width="1.2"/>
              </svg>
            ) : null}
            <div class="park-headline">
              <span class="park-total">{totalF != null ? (totalF >= 0 ? "+" : "") + totalF.toFixed(1) + "°F" : "—"}</span>
              <span class="park-since">since {p.period?.start_year ?? 1980}</span>
              {psig ? <span class="sig-mark" title={`${fmtSlope(slope)} °F/yr, p<0.05`}>✓</span> : null}
            </div>
            <div class="park-visual">
              <div class="stripes">
                {p.stripeColors.map((c: string) => <div style={`background:${c}`}></div>)}
              </div>
              {sparkD ? (
                <svg class="park-sparkline" viewBox="0 0 120 36" preserveAspectRatio="none" aria-hidden="true">
                  <path d={sparkD} fill="none" stroke="var(--ink)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              ) : null}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container section">
    <span class="kicker">Why this matters</span>
    <h2>Protected, but not immune</h2>
    <p style="max-width:720px">
      National parks were set aside to preserve scenic and ecological
      heritage — but they can't be fenced off from the climate. This
      project pulls the science out of research journals and into one
      place: every park's temperature, precipitation, snowpack, and
      evaporation record, from 1980 through today, with Mann-Kendall
      trend tests and Theil-Sen slopes applied consistently across units.
    </p>
    <div class="note">
      <strong>Researchers:</strong> the full pre-processed data is
      available as Parquet and CSV per park, and the analysis pipeline is
      reproducible from a single command. See the
      <a href={base + "researchers"}>researchers page</a>.
    </div>
  </section>
</Base>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script define:vars={{ base, parkSwarm, swarmMinF, swarmMaxF, REGION_ORDER }} is:inline>
  // National overview map — all 63 parks in a single neutral fill. Dot-swarm
  // below the map carries the warming-slope signal, so the map is free to
  // just be "where each park is."
  const cDeltaToF = (c) => (c == null || Number.isNaN(c)) ? null : c * 9 / 5;

  const mapEl = document.getElementById("overview-map");
  if (mapEl && window.L) {
    const map = L.map(mapEl, { scrollWheelZoom: false, worldCopyJump: false }).setView([39.5, -98.5], 3);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 12,
      opacity: 0.65,
    }).addTo(map);

    fetch(`${base}data/boundaries/all_parks.geojson`)
      .then((r) => r.json())
      .then((geo) => {
        L.geoJSON(geo, {
          style: () => ({
            color: "#1e1e1e",
            weight: 1,
            fillColor: "#c9c3b0",
            fillOpacity: 0.55,
          }),
          onEachFeature: (f, lyr) => {
            const p = f.properties;
            const slopeF = cDeltaToF(p.tmean_slope);
            const slopeStr = slopeF != null
              ? `${slopeF >= 0 ? "+" : ""}${slopeF.toFixed(3)} °F/yr${p.tmean_sig ? " · significant" : ""}`
              : "no trend data";
            lyr.bindTooltip(`<strong>${p.unit_name}</strong><br/>${slopeStr}`, { sticky: true });
            lyr.on("click", () => { window.location.href = `${base}parks/${p.slug}`; });
            lyr.on("mouseover", () => lyr.setStyle({ weight: 2, fillOpacity: 0.75 }));
            lyr.on("mouseout", () => lyr.setStyle({ weight: 1, fillOpacity: 0.55 }));
          },
        }).addTo(map);
      })
      .catch(() => {});
  }

  // Park-by-park swarm — every park's name, positioned by total warming
  // in °F since ~1980. Text labels replace dots so the chart reads as a
  // list instead of anonymous marks. Color ramp stays warm-sequential
  // but starts at terracotta (not near-white) so low-warming labels are
  // still legible on the near-white page background.
  function labelColor(valueF, minF, maxF) {
    if (valueF == null || Number.isNaN(valueF)) return "#8a8480";
    const t = Math.max(0, Math.min(1, (valueF - minF) / Math.max(1e-6, maxF - minF)));
    // Gold → amber → orange → red → maroon → near-black.
    // Five stops give more visible hue movement across the range; every
    // stop is still dark enough to read on the near-white page (#fcfcfc).
    // Kept in sync with .swarm-legend-bar gradient in global.css.
    const stops = [
      [0.00, [200, 155, 15]],
      [0.25, [220, 110, 20]],
      [0.50, [200, 55, 40]],
      [0.75, [130, 25, 40]],
      [1.00, [60, 10, 25]],
    ];
    let a = stops[0], b = stops[stops.length - 1];
    for (let i = 0; i < stops.length - 1; i++) {
      if (t >= stops[i][0] && t <= stops[i + 1][0]) { a = stops[i]; b = stops[i + 1]; break; }
    }
    const tt = (t - a[0]) / ((b[0] - a[0]) || 1);
    const r = Math.round(a[1][0] + (b[1][0] - a[1][0]) * tt);
    const g = Math.round(a[1][1] + (b[1][1] - a[1][1]) * tt);
    const bb = Math.round(a[1][2] + (b[1][2] - a[1][2]) * tt);
    return `rgb(${r},${g},${bb})`;
  }
  // Strip trailing "National Park [and Preserve]" so labels stay short.
  function shortName(n) {
    return n.replace(/ National Park and Preserve$/, "")
            .replace(/ National Park$/, "");
  }
  const swarmSvg = document.getElementById("swarm-svg");
  const swarmAxis = document.getElementById("swarm-axis");
  if (swarmSvg && parkSwarm && parkSwarm.length) {
    const W = 1000;
    const margin = { left: 20, right: 20, top: 14, bottom: 34 };
    const LINE_STEP = 13;
    const REGION_HEADER = 22;
    const LANE_PAD_TOP = 2;
    const LANE_PAD_BOTTOM = 10;
    const REGION_LABEL_Y_OFFSET = 11;
    const PAD_X = 3, PAD_Y = 1;
    const FONT_SIZE = 11;
    const svgNS = "http://www.w3.org/2000/svg";

    const presentRegions = REGION_ORDER
      .filter((r) => parkSwarm.some((p) => p.region === r))
      .slice()
      .sort((a, b) => a.localeCompare(b));
    const domain = swarmMaxF - swarmMinF;
    const xScale = (v) => margin.left + ((v - swarmMinF) / domain) * (W - margin.left - margin.right);

    // Two stacking groups so gridlines/separators paint behind labels
    // regardless of DOM insertion order.
    const gridGroup = document.createElementNS(svgNS, "g");
    const labelGroup = document.createElementNS(svgNS, "g");
    swarmSvg.appendChild(gridGroup);
    swarmSvg.appendChild(labelGroup);

    const tooltip = document.getElementById("swarm-tooltip");
    const swarmWrap = swarmSvg.parentElement;

    // Pass 1 — measure + collide per region. Each label greedily picks
    // the sub-row (0, -1, +1, -2, +2, …) closest to the midline that
    // doesn't overlap any previously placed label. No vertical bounds
    // yet, so the lane expands as tall as the densest cluster demands.
    const layouts = [];
    let cumulativeY = margin.top;

    for (const region of presentRegions) {
      const parksInRow = parkSwarm
        .filter((p) => p.region === region)
        .sort((a, b) => a.totalF - b.totalF);
      const placed = [];
      let minRow = 0, maxRow = 0;

      for (const park of parksInRow) {
        const x = xScale(park.totalF);
        const text = document.createElementNS(svgNS, "text");
        text.setAttribute("class", "park-label");
        text.setAttribute("text-anchor", "middle");
        text.setAttribute("dominant-baseline", "middle");
        text.setAttribute("font-size", String(FONT_SIZE));
        text.setAttribute("font-family", "Space Grotesk, sans-serif");
        text.setAttribute("font-weight", park.sig ? "600" : "400");
        text.setAttribute("font-style", park.sig ? "normal" : "italic");
        text.setAttribute("fill", labelColor(park.totalF, swarmMinF, swarmMaxF));
        text.setAttribute("fill-opacity", park.sig ? "1" : "0.55");
        text.textContent = shortName(park.unit_name);
        labelGroup.appendChild(text);
        const w = Math.max(24, text.getComputedTextLength());
        const h = FONT_SIZE + 2;

        let chosenRow = 0;
        for (let k = 0; k < 400; k++) {
          const row = k === 0 ? 0 : (k % 2 === 1 ? -Math.ceil(k / 2) : Math.ceil(k / 2));
          const relY = row * LINE_STEP;
          const hit = placed.some((q) => !(
            x + w / 2 + PAD_X < q.x - q.w / 2 ||
            x - w / 2 - PAD_X > q.x + q.w / 2 ||
            relY + h / 2 + PAD_Y < q.relY - q.h / 2 ||
            relY - h / 2 - PAD_Y > q.relY + q.h / 2
          ));
          if (!hit) { chosenRow = row; break; }
        }
        const relY = chosenRow * LINE_STEP;
        placed.push({ park, text, x, w, h, relY });
        if (chosenRow < minRow) minRow = chosenRow;
        if (chosenRow > maxRow) maxRow = chosenRow;

        const tipLabel = `${park.unit_name} · +${park.totalF.toFixed(2)} °F${park.sig ? " · significant" : ""}`;
        text.addEventListener("mousemove", (e) => {
          if (!tooltip || !swarmWrap) return;
          const rect = swarmWrap.getBoundingClientRect();
          tooltip.textContent = tipLabel;
          tooltip.style.left = (e.clientX - rect.left) + "px";
          tooltip.style.top = (e.clientY - rect.top) + "px";
          tooltip.classList.add("active");
        });
        text.addEventListener("mouseleave", () => {
          if (tooltip) tooltip.classList.remove("active");
        });
        text.addEventListener("click", () => { window.location.href = `${base}parks/${park.slug}`; });
      }

      const rowCount = maxRow - minRow + 1;
      const laneHeight = REGION_HEADER + LANE_PAD_TOP + rowCount * LINE_STEP + LANE_PAD_BOTTOM;
      const laneTopY = cumulativeY;
      const laneBottomY = laneTopY + laneHeight;
      const midlineY = laneTopY + REGION_HEADER + LANE_PAD_TOP + LINE_STEP / 2 + (-minRow) * LINE_STEP;
      layouts.push({ region, placed, laneTopY, laneBottomY, midlineY });
      cumulativeY = laneBottomY;
    }

    const H = cumulativeY + margin.bottom;
    swarmSvg.setAttribute("viewBox", `0 0 ${W} ${H}`);
    swarmSvg.setAttribute("height", String(H));

    // Pass 2 — integer gridlines span the full chart now that H is known.
    if (swarmAxis) swarmAxis.innerHTML = "";
    for (let v = swarmMinF; v <= swarmMaxF; v++) {
      const x = xScale(v);
      if (v !== 0) {
        const line = document.createElementNS(svgNS, "line");
        line.setAttribute("x1", x); line.setAttribute("x2", x);
        line.setAttribute("y1", margin.top);
        line.setAttribute("y2", H - margin.bottom);
        line.setAttribute("stroke", "#e2e0dc");
        line.setAttribute("stroke-width", "0.5");
        line.setAttribute("stroke-dasharray", "2 3");
        gridGroup.appendChild(line);
      }
      if (swarmAxis) {
        const span = document.createElement("span");
        span.textContent = v === 0 ? "0" : `+${v}°F`;
        span.style.position = "absolute";
        span.style.left = `${(x / W) * 100}%`;
        span.style.transform = "translateX(-50%)";
        swarmAxis.appendChild(span);
      }
    }

    // Pass 3 — region headers, separators, and final label positions.
    for (let i = 0; i < layouts.length; i++) {
      const { region, placed, laneTopY, laneBottomY, midlineY } = layouts[i];

      const regionLabel = document.createElementNS(svgNS, "text");
      regionLabel.setAttribute("x", String(margin.left));
      regionLabel.setAttribute("y", String(laneTopY + REGION_LABEL_Y_OFFSET));
      regionLabel.setAttribute("font-family", "Space Grotesk, sans-serif");
      regionLabel.setAttribute("font-size", "9.5");
      regionLabel.setAttribute("font-weight", "500");
      regionLabel.setAttribute("letter-spacing", "1.6");
      regionLabel.setAttribute("fill", "#6e6760");
      regionLabel.textContent = region.toUpperCase();
      gridGroup.appendChild(regionLabel);

      if (i < layouts.length - 1) {
        const sep = document.createElementNS(svgNS, "line");
        sep.setAttribute("x1", margin.left);
        sep.setAttribute("x2", W - margin.right);
        sep.setAttribute("y1", laneBottomY);
        sep.setAttribute("y2", laneBottomY);
        sep.setAttribute("stroke", "#eeece7");
        sep.setAttribute("stroke-width", "0.5");
        gridGroup.appendChild(sep);
      }

      for (const info of placed) {
        info.text.setAttribute("x", String(info.x));
        info.text.setAttribute("y", String(midlineY + info.relY));
      }
    }
  }
</script>
<script>
  const grid = document.getElementById("park-grid")!;
  const cards = Array.from(grid.querySelectorAll<HTMLAnchorElement>(".park-card"));
  const searchEl = document.getElementById("search") as HTMLInputElement;
  const sortEl = document.getElementById("sort") as HTMLSelectElement;
  const sigEl = document.getElementById("sig-only") as HTMLInputElement;
  const countEl = document.getElementById("result-count")!;
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>(".region-chips .chip"));

  let activeRegion = "all";

  // FLIP animation: snapshot positions, reorder/filter, then animate each
  // visible card from its previous rect to its new rect. Skipped for
  // users who prefer reduced motion.
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  function snapshot(): Map<HTMLAnchorElement, DOMRect> {
    const m = new Map<HTMLAnchorElement, DOMRect>();
    for (const c of cards) {
      if (c.style.display !== "none") m.set(c, c.getBoundingClientRect());
    }
    return m;
  }
  function animateFromSnapshot(before: Map<HTMLAnchorElement, DOMRect>) {
    if (prefersReducedMotion) return;
    for (const c of cards) {
      if (c.style.display === "none") continue;
      const prev = before.get(c);
      if (!prev) continue;
      const now = c.getBoundingClientRect();
      const dx = prev.left - now.left;
      const dy = prev.top - now.top;
      if (Math.abs(dx) < 1 && Math.abs(dy) < 1) continue;
      c.animate(
        [
          { transform: `translate(${dx}px, ${dy}px)` },
          { transform: "translate(0, 0)" },
        ],
        { duration: 260, easing: "cubic-bezier(0.23, 1, 0.32, 1)" },
      );
    }
  }

  function apply() {
    const before = snapshot();

    const q = searchEl.value.trim().toLowerCase();
    const sort = sortEl.value;
    const sigOnly = sigEl.checked;
    const visible: HTMLAnchorElement[] = [];
    for (const c of cards) {
      // data-state now carries both the 2-letter code AND the full state
      // name(s), space-separated, so "Utah" and "UT" both match.
      const nameMatch = !q || c.dataset.name!.includes(q) || c.dataset.state!.includes(q);
      const regionMatch = activeRegion === "all" || c.dataset.region === activeRegion;
      const sigMatch = !sigOnly || c.dataset.sig === "1";
      const show = nameMatch && regionMatch && sigMatch;
      c.style.display = show ? "" : "none";
      if (show) visible.push(c);
    }
    countEl.textContent = `${visible.length} park${visible.length === 1 ? "" : "s"}`;
    const byTotal = (a: HTMLAnchorElement, b: HTMLAnchorElement) =>
      parseFloat(b.dataset.total!) - parseFloat(a.dataset.total!);
    const byPrcp = (a: HTMLAnchorElement, b: HTMLAnchorElement) =>
      parseFloat(b.dataset.prcpSlope!) - parseFloat(a.dataset.prcpSlope!);
    const byName = (a: HTMLAnchorElement, b: HTMLAnchorElement) =>
      a.dataset.name!.localeCompare(b.dataset.name!);
    let sorted = visible.slice();
    if (sort === "warming") sorted.sort(byTotal);
    else if (sort === "cooling") sorted.sort((a, b) => -byTotal(a, b));
    else if (sort === "wetter") sorted.sort(byPrcp);
    else if (sort === "drier") sorted.sort((a, b) => -byPrcp(a, b));
    else sorted.sort(byName);
    sorted.forEach((c) => grid.appendChild(c));

    // After the DOM settles, animate cards from their old positions.
    requestAnimationFrame(() => animateFromSnapshot(before));
  }

  for (const chip of chips) {
    chip.addEventListener("click", () => {
      chips.forEach((c) => c.classList.remove("active"));
      chip.classList.add("active");
      activeRegion = chip.dataset.region || "all";
      apply();
    });
  }
  searchEl.addEventListener("input", apply);
  sortEl.addEventListener("change", apply);
  sigEl.addEventListener("change", apply);
  apply();
</script>
