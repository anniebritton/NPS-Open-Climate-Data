---
import "../styles/global.css";
const { title = "Open Climate Data — US National Parks", description = "Climate trends for every US National Park, 1980-present." } = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,900&family=Space+Grotesk:wght@400;500;600;700&display=swap" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-brand" href={base}>
          <span>Open Climate Data</span>
        </a>
        <div class="nav-links">
          <a href={base + "#parks"}>Parks</a>
          <a href={base + "methodology"}>Methodology</a>
          <a href={base + "researchers"}>For Researchers</a>
          <a href={base + "carbon"}>Carbon</a>
          <a href="https://github.com/anniebritton/NPS-Open-Climate-Data" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="footer-inner">
        <div>
          <div class="footer-section-label">Navigation</div>
          <nav class="footer-nav">
            <a href={base}>Home</a>
            <a href={base + "#parks"}>Parks</a>
            <a href={base + "methodology"}>Methodology</a>
            <a href={base + "researchers"}>For Researchers</a>
            <a href={base + "carbon"}>Carbon</a>
          </nav>
        </div>
        <div>
          <div class="footer-section-label">Data Sources</div>
          <div class="footer-col-body">
            DAYMET v4 &amp; ERA5-Land<br />via Google Earth Engine.<br />
            USGS PAD-US 4.1 boundaries.<br /><br />
            <a href={base + "methodology"}>Methodology</a> ·
            <a href={base + "carbon"}>Carbon footprint</a>
          </div>
        </div>
        <div>
          <div class="footer-section-label">About</div>
          <div class="footer-col-body">
            Open climate time series for<br />every US National Park.<br /><br />
            Annie Britton &amp; Ian Pritchard<br />MIT licensed<br /><br />
            <a href="https://github.com/anniebritton/NPS-Open-Climate-Data"
               target="_blank" rel="noopener"
               style="display:inline-block;font-family:'Space Grotesk',sans-serif;font-size:0.66rem;font-weight:500;letter-spacing:0.09em;text-transform:uppercase;padding:0.55rem 1.3rem;border:1.5px solid rgba(250,250,248,0.25);border-radius:9999px;color:rgba(250,250,248,0.8);transition:border-color 0.15s,color 0.15s">
              GitHub ↗
            </a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {year} Open Climate Data — US National Parks · MIT License</span>
        <span>Data: DAYMET v4 · ERA5-Land · USGS PAD-US</span>
      </div>
    </footer>

    <!-- Privacy / cookie disclosure banner.
         The site itself sets no tracking cookies and runs no analytics.
         Some third-party CDNs and font / map services receive IP
         addresses as part of normal HTTP requests; this banner is the
         transparency disclosure for that. Dismissed once and persisted
         in localStorage. -->
    <div id="cookie-banner" class="cookie-banner" role="region" aria-label="Privacy notice" hidden>
      <div class="cookie-banner-inner">
        <p>
          This site sets no tracking cookies and runs no analytics. It
          loads fonts (Google Fonts), Chart.js (jsDelivr), Leaflet
          (unpkg), and map tiles (OpenStreetMap), all of which receive
          your IP address as part of standard HTTP requests. Source code
          and a full privacy footprint live in the
          <a href="https://github.com/anniebritton/NPS-Open-Climate-Data" target="_blank" rel="noopener">GitHub repo</a>.
        </p>
        <button id="cookie-banner-ack" type="button" class="cookie-banner-btn">Got it</button>
      </div>
    </div>
    <script is:inline>
      (function () {
        var KEY = "nps-ocd-privacy-ack-v1";
        var banner = document.getElementById("cookie-banner");
        if (!banner) return;
        try {
          if (localStorage.getItem(KEY) === "1") return;
        } catch (e) { /* incognito with storage disabled — show anyway */ }
        banner.hidden = false;
        var btn = document.getElementById("cookie-banner-ack");
        if (btn) btn.addEventListener("click", function () {
          try { localStorage.setItem(KEY, "1"); } catch (e) {}
          banner.hidden = true;
        });
      })();
    </script>
  </body>
</html>
