---
import "../styles/global.css";
const { title = "NPS Open Climate Data", description = "Climate trends for every US National Park, 1980-present." } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,700;9..144,900&family=Inter:wght@400;600;700&display=swap" />
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-brand" href={base}>🌲 NPS Open Climate Data</a>
        <div class="nav-links">
          <a href={base + "#parks"}>Parks</a>
          <a href={base + "methodology"}>Methodology</a>
          <a href={base + "carbon"}>Carbon Footprint</a>
          <a href={base + "researchers"}>Researchers</a>
          <a href="https://github.com/anniebritton/NPS-Open-Climate-Data" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="container">
        <div>
          <strong style="color:var(--sun)">NPS Open Climate Data</strong><br />
          Open, pre-processed climate time series for every US National Park.<br />
          Annie Britton &amp; Ian Pritchard · MIT licensed ·
          <a href="https://github.com/anniebritton/NPS-Open-Climate-Data">GitHub</a>
        </div>
        <div>
          Built with DAYMET v4 &amp; ERA5-Land via Google Earth Engine.<br />
          Boundaries from USGS PAD-US v20.<br />
          <a href={base + "methodology"}>Methodology</a> · <a href={base + "carbon"}>Carbon footprint</a>
        </div>
      </div>
    </footer>
  </body>
</html>
